# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Models (change here to swap globally) ─────────────────────────────────────
# Agent 1 (SQL Analyst) + Agent 2 (Anomaly Detector) use Haiku — structured output, cost-efficient
HAIKU_MODEL=claude-haiku-4-5
# Agent 3 (Report Writer) uses Sonnet — narrative quality matters here
SONNET_MODEL=claude-sonnet-4-6

# ── AWS S3 (optional — project runs fully offline without these) ───────────────
# If you have an AWS account, create a bucket and IAM user with S3 write access
# Leave blank to run in local-only mode — the push_s3.py script will skip gracefully
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=patientpoint-campaign-intelligence

# ── Local paths (defaults are relative to project root — change only if needed) ─
DB_PATH=data/campaign_data.db
EXPORTS_DIR=exports
